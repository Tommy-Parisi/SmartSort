{
  "productName": "Smart Sort",
  "version": "0.1.0",
  "identifier": "com.filesort.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Smart Sort",
        "width": 900,
        "height": 700
      }
    ]
  },
  "bundle": {
    "active": true,
    "resources": {
      "../../backend/agents/*.py":   "backend/agents/",
      "../../backend/core/*.py":     "backend/core/",
      "../../backend/pipeline/*.py": "backend/pipeline/",
      "../../backend/daemon/*.py":   "backend/daemon/",
      "../../backend/__init__.py":   "backend/"
    }
  }
}
